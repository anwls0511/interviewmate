<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.interviewmate.payment.mapper.PaymentMapper">

    <insert id="insertPayment"
            parameterType="com.interviewmate.payment.domain.Payment"
            useGeneratedKeys="true"
            keyProperty="paymentId">

        INSERT INTO payments
        (
            user_id,
            plan_type,
            amount,
            status
        )
        VALUES
            (
                #{userId},
                #{planType},
                #{amount},
                #{status}
            )

    </insert>

    <select id="findByUserId"
            parameterType="long"
            resultType="com.interviewmate.payment.domain.Payment">

        SELECT
            payment_id,
            user_id,
            plan_type,
            amount,
            status,
            paid_at,
            created_at
        FROM payments
        WHERE user_id = #{userId}
        ORDER BY paid_at DESC

    </select>

</mapper>